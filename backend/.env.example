# Copy this file to .env and fill in real values. Never commit .env.

# Get a token at https://huggingface.co/settings/tokens
# IMPORTANT: if you ever paste a real token into a chat, doc, or commit,
# treat it as compromised and rotate it immediately at the link above.
HF_API_TOKEN= 

# Change this to a long random string in any real deployment.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

# Swap models without touching code:
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_RERANKER_MODEL=BAAI/bge-reranker-base

# Free local SQLite database; point at Postgres in production, e.g.
# DATABASE_URL=postgresql://user:pass@host:5432/asktheco
DATABASE_URL=sqlite:///./data/asktheco.db

TOP_K=6
ENABLE_RERANKING=true
RERANK_CANDIDATE_K=20
FUZZY_DEDUP_THRESHOLD=0.92
BM25_WEIGHT=0.4
DENSE_WEIGHT=0.6
CHUNK_SIZE_CHARS=1200
CHUNK_OVERLAP_CHARS=150
